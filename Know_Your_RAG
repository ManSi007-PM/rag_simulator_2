<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive RAG Architecture Simulator</title>
    <style>
        :root {
            --bg-main: #121820;
            --bg-card: #1e2631;
            --bg-input: #171d26;
            --border-color: #2e3b4e;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --mint-primary: #34d399;
            --mint-glow: rgba(52, 211, 153, 0.15);
            --blue-accent: #60a5fa;
            --step-active: #f59e0b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            padding: 30px;
            line-height: 1.5;
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 30px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 20px;
        }

        header h1 {
            font-size: 24px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        header h1 span {
            color: var(--mint-primary);
            font-size: 14px;
            background: var(--mint-glow);
            padding: 4px 8px;
            border-radius: 4px;
            border: 1px solid rgba(52, 211, 153, 0.3);
        }

        header p {
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 5px;
        }

        .grid-layout {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 25px;
        }

        /* Left Config Panel */
        .panel {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            height: fit-content;
        }

        .panel-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            color: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        label {
            display: block;
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 8px;
            font-weight: 500;
        }

        textarea, input[type="text"] {
            width: 100%;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: #fff;
            padding: 12px;
            font-size: 14px;
            resize: vertical;
            margin-bottom: 20px;
            transition: border 0.2s;
        }

        textarea:focus, input[type="text"]:focus {
            outline: none;
            border-color: var(--mint-primary);
        }

        .btn {
            width: 100%;
            background: var(--mint-primary);
            color: #0f172a;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            font-size: 14px;
            transition: opacity 0.2s;
        }

        .btn:hover {
            opacity: 0.9;
        }

        /* Right Pipeline Execution Area */
        .pipeline {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Step Card Styling */
        .step-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            position: relative;
            opacity: 0.5;
            transition: all 0.3s ease;
        }

        .step-card.active {
            opacity: 1;
            border-color: var(--step-active);
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.1);
        }

        .step-card.completed {
            opacity: 1;
            border-color: var(--mint-primary);
        }

        .step-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .step-badge {
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            background: var(--border-color);
            padding: 3px 8px;
            border-radius: 4px;
            color: var(--text-muted);
        }

        .step-card.active .step-badge {
            background: var(--step-active);
            color: #000;
        }

        .step-card.completed .step-badge {
            background: var(--mint-primary);
            color: #000;
        }

        .step-title {
            font-size: 16px;
            font-weight: 600;
            color: #fff;
        }

        .step-description {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 15px;
        }

        /* Execution Data Layouts */
        .data-display {
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 13px;
            color: var(--blue-accent);
            white-space: pre-wrap;
            max-height: 250px;
            overflow-y: auto;
        }

        .vector-chunk {
            border-bottom: 1px solid #2e3b4e;
            padding: 8px 0;
        }
        .vector-chunk:last-child { border: none; }

        .match-highlight {
            color: var(--mint-primary);
            font-weight: bold;
        }

        .prompt-box {
            color: #f1f5f9;
        }
        .prompt-accent {
            color: var(--step-active);
        }

        /* Controls */
        .pipeline-controls {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
        }

        .control-btn {
            flex: 1;
            background: var(--border-color);
            border: 1px solid #475569;
            color: #fff;
            padding: 10px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
        }

        .control-btn:hover {
            background: #334155;
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>RAG Architecture Simulator <span>Sandbox v1.0</span></h1>
            <p>An interactive, local playground mapping out how Retrieval-Augmented Generation bridges user queries and localized knowledge bases.</p>
        </header>

        <div class="grid-layout">
            
            <div class="panel">
                <div class="panel-title">In-Memory Data Source</div>
                
                <label for="knowledgeBase">Documents (One per line)</label>
                <textarea id="knowledgeBase" rows="8">The standard speed of light is 299,792 kilometers per second.
The dynamic AI model called Gemini was developed by Google.
Revere Beach is a historic shoreline located in Massachusetts.
The current year is 2026.
The culinary dish 'Ratatouille' is an stewed vegetable recipe originating from France.</textarea>

                <label for="userQuery">User Query (Prompt)</label>
                <input type="text" id="userQuery" value="Who built the Gemini AI model and where is Revere beach?">

                <div class="pipeline-controls">
                    <button class="control-btn" onclick="resetSimulator()">Reset</button>
                    <button class="control-btn" style="background: rgba(245,158,11,0.2); border-color: var(--step-active);" onclick="nextStep()">Step Forward →</button>
                </div>
                <button class="btn" onclick="runFullPipeline()">Execute Full Pipeline</button>
            </div>

            <div class="pipeline">
                
                <div class="step-card" id="step1">
                    <div class="step-header">
                        <div class="step-title">Step 1: Document Chunking & Vectorization</div>
                        <div class="step-badge" id="badge1">Idle</div>
                    </div>
                    <p class="step-description">The knowledge base strings are broken down into searchable chunks. In production, an embedding model turns these into multi-dimensional float vectors representing semantic meaning.</p>
                    <div class="data-display" id="output1">// Awaiting compilation...</div>
                </div>

                <div class="step-card" id="step2">
                    <div class="step-header">
                        <div class="step-title">Step 2: Query Embedding & Semantic Matching</div>
                        <div class="step-badge" id="badge2">Idle</div>
                    </div>
                    <p class="step-description">The user's query is transformed into the same vector space. A distance calculation (like Cosine Similarity) flags the top vector matches with relevant data kernels.</p>
                    <div class="data-display" id="output2">// Awaiting execution context...</div>
                </div>

                <div class="step-card" id="step3">
                    <div class="step-header">
                        <div class="step-title">Step 3: Augmenting the Prompt Context</div>
                        <div class="step-badge" id="badge3">Idle</div>
                    </div>
                    <p class="step-description">The system injects the retrieved context directly into a pre-structured engineering framework alongside the user's base prompt request.</p>
                    <div class="data-display" id="output3">// Awaiting contextual assembly...</div>
                </div>

                <div class="step-card" id="step4">
                    <div class="step-header">
                        <div class="step-title">Step 4: LLM Generation</div>
                        <div class="step-badge" id="badge4">Idle</div>
                    </div>
                    <p class="step-description">The LLM processes the unified payload, ensuring facts are grounded explicitly in the retrieved parameters instead of hallucinated guessing data.</p>
                    <div class="data-display" id="output4" style="color: #fff; font-weight: bold;">// Awaiting final output matrix...</div>
                </div>

            </div>
        </div>
    </div>

    <script>
        let currentStep = 0;
        let cachedChunks = [];
        let matchedContext = [];

        // Simple mock bag-of-words keyword intersection overlap to simulate semantic search natively
        function getMockSimilarity(text1, text2) {
            const tokens1 = text1.toLowerCase().match(/\b\w+\b/g) || [];
            const tokens2 = text2.toLowerCase().match(/\b\w+\b/g) || [];
            const set2 = new Set(tokens2);
            const intersection = tokens1.filter(x => set2.has(x));
            return (intersection.length / Math.max(1, Math.sqrt(tokens1.length * tokens2.length))).toFixed(3);
        }

        function resetSimulator() {
            currentStep = 0;
            cachedChunks = [];
            matchedContext = [];
            
            for(let i=1; i<=4; i++) {
                const card = document.getElementById(`step${i}`);
                const badge = document.getElementById(`badge${i}`);
                const output = document.getElementById(`output${i}`);
                
                card.className = "step-card";
                badge.innerText = "Idle";
                output.innerHTML = i === 4 ? "// Awaiting final output matrix..." : "// Awaiting data processing...";
            }
        }

        function nextStep() {
            if (currentStep >= 4) return;
            currentStep++;
            executeStep(currentStep);
        }

        function runFullPipeline() {
            resetSimulator();
            for(let i = 1; i <= 4; i++) {
                executeStep(i);
            }
            currentStep = 4;
        }

        function executeStep(stepId) {
            const card = document.getElementById(`step${stepId}`);
            const badge = document.getElementById(`badge${stepId}`);
            const output = document.getElementById(`output${stepId}`);
            
            // Adjust CSS States
            card.className = "step-card active";
            badge.innerText = "Active";

            const kbInput = document.getElementById("knowledgeBase").value;
            const queryInput = document.getElementById("userQuery").value;

            if (stepId === 1) {
                // Parse text areas as array blocks
                cachedChunks = kbInput.split("\n").filter(line => line.trim() !== "");
                let htmlOut = `[SYSTEM_LOG] Tokenizing and vectorizing ${cachedChunks.length} documents...\n\n`;
                
                cachedChunks.forEach((chunk, index) => {
                    // Generate a deterministic mock float vector array to simulate embeddings visuality
                    let mockVector = Array.from({length: 4}, () => (Math.random() * 2 - 1).toFixed(4));
                    htmlOut += `<div class="vector-chunk"><strong>[Doc Chunk #${index + 1}]:</strong> "${chunk}"\n<span style="color: var(--text-muted)">↳ Embedding Space Vector: [${mockVector.join(", ")}, ...]</span></div>`;
                });
                output.innerHTML = htmlOut;
                card.className = "step-card completed";
                badge.innerText = "Completed";
            } 
            
            else if (stepId === 2) {
                if(cachedChunks.length === 0) cachedChunks = kbInput.split("\n").filter(line => line.trim() !== "");
                
                let scores = cachedChunks.map((chunk, index) => {
                    return {
                        text: chunk,
                        id: index + 1,
                        score: parseFloat(getMockSimilarity(chunk, queryInput))
                    };
                });

                // Sort records descending by calculated mock weight relevance scores
                scores.sort((a,b) => b.score - a.score);
                
                // Select top 2 elements matching
                matchedContext = scores.slice(0, 2).filter(item => item.score > 0);
                if(matchedContext.length === 0 && scores.length > 0) matchedContext = [scores[0]]; // fallback top match

                let htmlOut = `[SYSTEM_LOG] Scanning spatial indexes against Query Vector...\n\n`;
                scores.forEach(item => {
                    let isMatch = matchedContext.some(m => m.id === item.id);
                    let visualClass = isMatch ? "class='match-highlight'" : "";
                    htmlOut += `<div ${visualClass}>→ Similarity Score: ${item.score} | Chunk #${item.id}: "${item.text}" ${isMatch ? ' [RETRIEVED]' : ''}</div>`;
                });
                
                output.innerHTML = htmlOut;
                card.className = "step-card completed";
                badge.innerText = "Completed";
            } 
            
            else if (stepId === 3) {
                if(matchedContext.length === 0) {
                    // Quick fallback generation if skipped straight to step 3
                    matchedContext = [{text: "The dynamic AI model called Gemini was developed by Google.", id: 2}];
                }
                
                let contextString = matchedContext.map(m => m.text).join("\n");
                
                let htmlOut = `<span class="prompt-accent">📂 System Prompt Instructions:</span>\n`;
                htmlOut += `<span class="prompt-box">"You are a helpful assistant. Use only the following extracted context elements to answer the question. If you don't know, say you don't know."</span>\n\n`;
                htmlOut += `<span class="prompt-accent">📦 Injected Context Extracted:</span>\n`;
                htmlOut += `<span class="prompt-box">${contextString}</span>\n\n`;
                htmlOut += `<span class="prompt-accent">👤 User Dynamic Question:</span>\n`;
                htmlOut += `<span class="prompt-box">"${queryInput}"</span>`;
                
                output.innerHTML = htmlOut;
                card.className = "step-card completed";
                badge.innerText = "Completed";
            } 
            
            else if (stepId === 4) {
                let contextText = matchedContext.map(m => m.text).join(" ").toLowerCase();
                let outputAnswer = "The provided context does not contain sufficient elements to form a verified answer to your prompt metrics.";
                
                // Deterministic check to resolve response natively without server dependencies
                let answers = [];
                if(contextText.includes("gemini") || queryInput.toLowerCase().includes("gemini")) {
                    answers.push("Google developed the dynamic AI model named Gemini.");
                }
                if(contextText.includes("revere") || queryInput.toLowerCase().includes("revere")) {
                    answers.push("Revere Beach is a historic coastline situated in Massachusetts.");
                }
                if(contextText.includes("light") || queryInput.toLowerCase().includes("light")) {
                    answers.push("The standard speed of light moves at 299,792 km/s.");
                }

                if(answers.length > 0) {
                    outputAnswer = answers.join(" ");
                }

                output.innerHTML = `[LLM RESPONSE ENGINE]:\n\n"${outputAnswer}"\n\n<span style="color: var(--mint-primary); font-family: sans-serif; font-size: 11px;">✔ Grounded output generated with zero factual hallucinations based on provided contexts.</span>`;
                card.className = "step-card completed";
                badge.innerText = "Completed";
            }
        }
    </script>
</body>
</html>
